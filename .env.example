# Copy this file to .env and fill in values before running locally.
# Do not commit .env to version control.

# API key required for authenticated endpoints (/v1/action/score, /v1/evidence/check)
# Demo endpoints (/v1/action/score/demo, /v1/evidence/check/demo) do not require a key.
AITAPP_API_KEY=dev-key-change-in-production

# Base URL of the running API server.
# Local:  http://127.0.0.1:8000
# Remote: https://your-app.railway.app
AITAPP_API_URL=http://127.0.0.1:8000
